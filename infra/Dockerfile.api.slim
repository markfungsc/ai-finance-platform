# Inference-only API image (no PyTorch / FinBERT). For EC2 t3.micro and AWS deploy.
# Local Compose with NLP in API: use Dockerfile.api instead.
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY src /app/src
COPY data /app/data

ENV PYTHONPATH=/app/src

EXPOSE 8000

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
