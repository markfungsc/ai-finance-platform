# Full API image including NLP stack (FinBERT). For local Compose; EC2 uses Dockerfile.api.slim.
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt requirements-nlp.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-nlp.txt

COPY src /app/src
COPY data /app/data

ENV PYTHONPATH=/app/src

EXPOSE 8000

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
